# ─────────────────────────────────────────────────────────────
# fav-beauty runs with ZERO configuration.
# Leave everything below unset to use the built-in demo data
# (seed treatments, products, stylists, membership tiers).
#
# To connect a real FavCRM workspace, set VITE_FAVCRM_COMPANY_ID
# to your workspace UUID — the data provider switches to live mode.
# ─────────────────────────────────────────────────────────────

# Optional — FavCRM workspace UUID. Unset = demo mode.
# VITE_FAVCRM_COMPANY_ID=00000000-0000-0000-0000-000000000000

# Optional — defaults to https://api.favcrm.io
# VITE_FAVCRM_API_URL=https://api.favcrm.io

# Optional — public site URL, used for SEO metadata.
# VITE_SITE_URL=https://your-salon.example.com
